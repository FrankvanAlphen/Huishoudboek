# --- Database -------------------------------------------------------------
# Railway levert deze automatisch wanneer je de PostgreSQL-plugin koppelt.
DATABASE_URL=postgres://user:password@localhost:5432/finance

# --- Auth (gedeelde huishoud-login) --------------------------------------
# Genereer de hash eenmalig met:  npm run hash-password -- "JouwWachtwoord"
AUTH_PASSWORD_HASH=

# Willekeurige lange string voor het ondertekenen van sessiecookies.
# Genereer bijvoorbeeld met:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=

# --- Server ---------------------------------------------------------------
PORT=3000
NODE_ENV=development
