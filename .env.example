# ====== Verplicht voor blijvende, veilige opslag ======

# 1) Database (gebruikers, logboek en data). Op Railway: voeg een Postgres-service
#    toe en verwijs hiernaar met ${{Postgres.DATABASE_URL}}.
DATABASE_URL=

# 2) Geheime sleutel voor het inlog-cookie. ZET DEZE op een lange willekeurige tekst.
#    Zonder APP_SECRET maakt de server een tijdelijke sleutel en moet je na elke
#    herstart opnieuw inloggen. Genereer er een met:
#       node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=

# ====== Optioneel ======

# Startwachtwoorden buiten de broncode houden (alleen gebruikt bij de allereerste
# keer dat een gebruiker wordt aangemaakt; daarna telt je eigen gekozen wachtwoord):
# FRANK_TEMP_PW=
# KIMBERLEY_TEMP_PW=

# Alleen als je database SSL vereist (Railway intern niet; extern vaak wel):
# DATABASE_SSL=true

# Alleen voor lokaal testen op http:// (zet cookies dan zonder Secure-vlag):
# COOKIE_INSECURE=true
